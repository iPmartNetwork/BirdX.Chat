# ========================================
# BirdX Environment Configuration
# ========================================

# Server
SERVER_PORT=5174
CLIENT_PORT=80

# App (use development for `npm run dev`; production needs `npm run build` first)
APP_ENV=production
APP_DEBUG=false
# Socket.io CORS allow-list (comma/space separated). Leave empty to allow any
# origin (session auth is still enforced). Capacitor/mobile origins are always allowed.
# APP_ALLOWED_ORIGINS=https://app.birdx.chat https://web.birdx.chat

# Auth
ACCOUNT_CREATION=true
# Comma-separated bootstrap owner usernames (default BirdX system account)
ADMIN_USERNAMES=birdxchat

# File Upload
FILE_UPLOAD=true
FILE_UPLOAD_MAX_SIZE=52428800
FILE_UPLOAD_MAX_TOTAL_SIZE=157286400
FILE_UPLOAD_MAX_FILES=10
FILE_UPLOAD_TRANSCODE_VIDEOS=true

# Message Limits
MESSAGE_MAX_CHARS=4000

# Retention (days)
MESSAGE_FILE_RETENTION=7
MESSAGE_TEXT_RETENTION=0

# Chat Performance
CHAT_MESSAGE_FETCH_LIMIT=300
CHAT_MESSAGE_PAGE_SIZE=60
CHAT_LIST_REFRESH_INTERVAL=20000

# Presence
CHAT_PRESENCE_PING_INTERVAL=5000

# Voice calls
# Group calls: mesh (default) or sfu (mediasoup). SFU needs UDP ports 40000-49999 open.
GROUP_CALL_MODE=mesh
# GROUP_CALL_MODE=sfu
# MEDIASOUP_LISTEN_IP=0.0.0.0
# MEDIASOUP_ANNOUNCED_IP=your.public.ip
GROUP_CALL_MIN_MEMBERS=10
GROUP_CALL_MAX_PARTICIPANTS=20
# STUN is built in. TURN is also served at runtime via GET /api/app/info (rtc.iceServers).
# Still set these here — used when building the client and as the server source of truth.
APP_TURN_URLS=turn:turn.birdx.chat:3478?transport=udp turn:turn.birdx.chat:3478?transport=tcp
APP_TURN_USERNAME=birdx
APP_TURN_CREDENTIAL=

CHAT_VOICE_WAVEFORM_MAX_DECODE_BYTES=5242880
CHAT_VOICE_WAVEFORM_MAX_DECODE_SECONDS=480

# Remote Channel (Telegram -> BirdX channel)
REMOTE_CHANNEL=false
REMOTE_CHANNEL_TELEGRAM_API_ID=0
REMOTE_CHANNEL_TELEGRAM_API_HASH=
REMOTE_CHANNEL_TELEGRAM_SESSION_STRING=
REMOTE_CHANNEL_PROXY_URL=
REMOTE_CHANNEL_POLL_INTERVAL_MS=5000
REMOTE_CHANNEL_TELEGRAM_POLL_LIMIT=50
REMOTE_CHANNEL_QUEUE_INTERVAL_MS=1000
REMOTE_CHANNEL_QUEUE_MAX_ATTEMPTS=10
REMOTE_CHANNEL_QUEUE_STALE_LOCK_MS=300000

# Security (AUTO GENERATED ON FIRST RUN)
STORAGE_ENCRYPTION_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Deploy (optional — for documentation / systemd)
# BIRDX_SERVICE_NAME=birdx.service
# BIRDX_SERVICE_USER=birdx
# Public URLs: birdx.chat (site), web.birdx.chat (PWA), app.birdx.chat (mobile)

# ========================================
# Notes:
# - Do NOT change STORAGE_ENCRYPTION_KEY after first run
# - HTTPS is required for push notifications
# - Use .env (not .env.example) in production
# - Database file: data/birdx.db (legacy songbird.db migrates on startup)
# ========================================
