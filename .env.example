# ========================================
# BirdX Environment Configuration
# ========================================

# Server
SERVER_PORT=5174
CLIENT_PORT=80

# App
APP_ENV=production
APP_DEBUG=false

# Auth
ACCOUNT_CREATION=true
# Comma-separated bootstrap owner usernames, for example: ADMIN_USERNAMES=admin
ADMIN_USERNAMES=

# File Upload
FILE_UPLOAD=true
FILE_UPLOAD_MAX_SIZE=26214400
FILE_UPLOAD_MAX_TOTAL_SIZE=78643200
FILE_UPLOAD_MAX_FILES=10
FILE_UPLOAD_TRANSCODE_VIDEOS=true

# Message Limits
MESSAGE_MAX_CHARS=4000

# Retention (days)
MESSAGE_FILE_RETENTION=7
MESSAGE_TEXT_RETENTION=0

# Chat Performance
CHAT_MESSAGE_FETCH_LIMIT=300
CHAT_MESSAGE_PAGE_SIZE=60
CHAT_LIST_REFRESH_INTERVAL=20000

# Presence
CHAT_PRESENCE_PING_INTERVAL=5000

# Voice calls
# STUN is built in. Add a TURN server for reliable audio on mobile carriers,
# strict NATs, and corporate Wi-Fi.
APP_TURN_URLS=
APP_TURN_USERNAME=
APP_TURN_CREDENTIAL=

# Remote Channel (Telegram -> BirdX channel)
REMOTE_CHANNEL=false
REMOTE_CHANNEL_TELEGRAM_API_ID=0
REMOTE_CHANNEL_TELEGRAM_API_HASH=
REMOTE_CHANNEL_TELEGRAM_SESSION_STRING=
REMOTE_CHANNEL_PROXY_URL=
REMOTE_CHANNEL_POLL_INTERVAL_MS=5000
REMOTE_CHANNEL_TELEGRAM_POLL_LIMIT=50
REMOTE_CHANNEL_QUEUE_INTERVAL_MS=1000
REMOTE_CHANNEL_QUEUE_MAX_ATTEMPTS=10
REMOTE_CHANNEL_QUEUE_STALE_LOCK_MS=300000

# Security (AUTO GENERATED ON FIRST RUN)
STORAGE_ENCRYPTION_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ========================================
# Notes:
# - Do NOT change STORAGE_ENCRYPTION_KEY after first run
# - HTTPS is required for push notifications
# - Use .env (not .env.example) in production
# ========================================
