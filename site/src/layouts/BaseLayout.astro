---
import '../styles/global.css'

const { title = 'BirdX', description = 'Secure chat & file sharing platform', lang = 'en', dir = 'ltr' } = Astro.props
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" href="/icons/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/icon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/icon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-180.png" />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://birdx.chat" />
    <meta property="og:image" content="https://birdx.chat/icons/icon-512.png" />

    <!-- Theme -->
    <meta name="theme-color" content="#ffffff" />

    <title>{title}</title>

    <!-- Theme Loader (prevent flash) -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('birdx-site-theme');
        if (stored === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class={`min-h-screen antialiased ${dir === 'rtl' ? 'font-fa' : 'font-sans'}`}>
    <slot />

    <!-- Theme & Language Scripts -->
    <script is:inline>
      // Scroll fade-in animation
      document.addEventListener('DOMContentLoaded', function() {
        var sections = document.querySelectorAll('.fade-in-section');
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        sections.forEach(function(section) { observer.observe(section); });
      });
    </script>
  </body>
</html>
