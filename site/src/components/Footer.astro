---
const { t, lang } = Astro.props
const otherLangUrl = lang === 'en' ? '/' : '/en'
const otherLangLabel = lang === 'en' ? 'فارسی' : 'English'
---

<footer class="border-t border-slate-100 bg-slate-50 py-14 dark:border-slate-800 dark:bg-[#0f172a]">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <img src="/birdx-logo.svg" alt="BirdX" class="mb-3 h-6" />
        <p class="text-xs leading-relaxed text-slate-500 dark:text-slate-400">
          Secure, fast, and self-hosted messaging platform for teams and individuals.
        </p>
        <!-- Social -->
        <div class="mt-5 flex gap-2.5">
          <a href="https://github.com/iPmartNetwork/BirdX.Chat" target="_blank" rel="noopener" class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-slate-500 transition-colors hover:bg-emerald-50 hover:text-emerald-600 dark:bg-slate-800 dark:text-slate-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-400">
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>

      <!-- Product -->
      <div>
        <h4 class="mb-3 text-xs font-bold uppercase tracking-wider text-slate-900 dark:text-white">{t.footer.product}</h4>
        <ul class="space-y-2">
          <li><a href="#features" class="text-xs text-slate-500 transition-colors hover:text-emerald-600 dark:text-slate-400 dark:hover:text-emerald-400">{t.footer.features}</a></li>
          <li><a href="#download" class="text-xs text-slate-500 transition-colors hover:text-emerald-600 dark:text-slate-400 dark:hover:text-emerald-400">{t.footer.download}</a></li>
          <li><a href="#security" class="text-xs text-slate-500 transition-colors hover:text-emerald-600 dark:text-slate-400 dark:hover:text-emerald-400">{t.footer.security}</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="mb-3 text-xs font-bold uppercase tracking-wider text-slate-900 dark:text-white">{t.footer.resources}</h4>
        <ul class="space-y-2">
          <li><a href="https://github.com/iPmartNetwork/BirdX.Chat" target="_blank" rel="noopener" class="text-xs text-slate-500 transition-colors hover:text-emerald-600 dark:text-slate-400 dark:hover:text-emerald-400">{t.footer.github}</a></li>
          <li><a href="https://github.com/iPmartNetwork/BirdX.Chat#readme" target="_blank" rel="noopener" class="text-xs text-slate-500 transition-colors hover:text-emerald-600 dark:text-slate-400 dark:hover:text-emerald-400">{t.footer.docs}</a></li>
          <li><a href="https://github.com/iPmartNetwork/BirdX.Chat/issues" target="_blank" rel="noopener" class="text-xs text-slate-500 transition-colors hover:text-emerald-600 dark:text-slate-400 dark:hover:text-emerald-400">{t.footer.issues}</a></li>
        </ul>
      </div>

      <!-- Language -->
      <div>
        <h4 class="mb-3 text-xs font-bold uppercase tracking-wider text-slate-900 dark:text-white">Language</h4>
        <div class="flex flex-col gap-1.5">
          <a href="/en" class={`flex items-center gap-2 rounded-lg px-3 py-1.5 text-xs transition-colors ${lang === 'en' ? 'bg-emerald-50 text-emerald-700 font-medium dark:bg-emerald-500/10 dark:text-emerald-400' : 'text-slate-500 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800'}`}>
            <span>🇺🇸</span> English
          </a>
          <a href="/" class={`flex items-center gap-2 rounded-lg px-3 py-1.5 text-xs transition-colors ${lang === 'fa' ? 'bg-emerald-50 text-emerald-700 font-medium dark:bg-emerald-500/10 dark:text-emerald-400' : 'text-slate-500 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800'}`}>
            <span>🇮🇷</span> فارسی
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-slate-200 pt-6 dark:border-slate-700/50 sm:flex-row">
      <p class="text-[11px] text-slate-400">{t.footer.rights}</p>
      <a href={otherLangUrl} class="text-[11px] text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400">{otherLangLabel}</a>
    </div>
  </div>
</footer>
