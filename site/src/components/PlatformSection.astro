---
const { t, lang } = Astro.props

const platforms = {
  en: {
    title: 'AVAILABLE EVERYWHERE YOU ARE',
    description: 'On your PC, phone, or tablet — BirdX is always with you. Switch between devices seamlessly and keep your conversations in sync.',
    items: [
      { name: 'Windows', status: 'soon', icon: 'windows' },
      { name: 'Android', status: 'soon', icon: 'android' },
      { name: 'iOS', status: 'soon', icon: 'ios' },
      { name: 'Web', status: 'live', icon: 'web' },
    ],
  },
  fa: {
    title: 'هر جا هستی، بردایکس هست',
    description: 'کامپیوتر، گوشی یا تبلت — فرقی نمیکنه. بین دستگاه‌هات جابجا شو و چت‌هات همه جا باهاتن.',
    items: [
      { name: 'ویندوز', status: 'soon', icon: 'windows' },
      { name: 'اندروید', status: 'soon', icon: 'android' },
      { name: 'آی‌او‌اس', status: 'soon', icon: 'ios' },
      { name: 'وب', status: 'live', icon: 'web' },
    ],
  },
}

const data = platforms[lang] || platforms.en
const statusLabel = lang === 'fa' ? { live: 'فعال', soon: 'به زودی' } : { live: 'LIVE', soon: 'SOON' }
---

<section id="download" class="section-block">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-[#0f172a] via-[#1e293b] to-[#0f172a] p-8 sm:p-12 lg:p-16">
      <!-- Background glow -->
      <div class="absolute top-0 right-0 h-[400px] w-[400px] rounded-full bg-emerald-500/10 blur-[100px]"></div>
      <div class="absolute bottom-0 left-0 h-[300px] w-[300px] rounded-full bg-teal-500/10 blur-[80px]"></div>

      <div class="relative flex flex-col items-center gap-12 lg:flex-row lg:gap-16">
        <!-- Text -->
        <div class="flex-1 text-center lg:text-start">
          <h2 class="text-2xl font-extrabold uppercase tracking-tight text-white sm:text-3xl lg:text-4xl">
            {data.title}
          </h2>
          <p class="mt-4 max-w-md text-sm leading-relaxed text-slate-400 sm:text-base">
            {data.description}
          </p>
        </div>

        <!-- Platform Cards with animation -->
        <div class="flex-1">
          <div class="relative flex items-center justify-center py-8">
            <!-- Main featured card (Web - active) -->
            <div class="platform-main-card relative z-10 rounded-2xl border border-slate-600/50 bg-gradient-to-br from-slate-700/80 to-slate-800/80 p-6 shadow-2xl backdrop-blur-sm">
              <div class="flex items-center justify-center">
                <div class="flex h-24 w-24 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 shadow-lg shadow-emerald-500/20 sm:h-28 sm:w-28">
                  <!-- Web/Globe icon -->
                  <svg class="h-12 w-12 text-white sm:h-14 sm:w-14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
                  </svg>
                </div>
              </div>
              <p class="mt-3 text-center text-xs font-medium text-slate-300">Web App</p>
            </div>

            <!-- Floating platform icons with animations -->
            <!-- Windows - top left, floating up/down -->
            <div class="platform-float-1 absolute -top-2 left-[15%] flex h-12 w-12 items-center justify-center rounded-full border border-slate-600/50 bg-slate-700/90 shadow-lg backdrop-blur-sm sm:h-14 sm:w-14">
              <svg class="h-6 w-6 text-sky-400 sm:h-7 sm:w-7" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 12.5L3 5.5L10.5 4.5V12.5H3ZM3 13.5H10.5V21.5L3 20.5V13.5ZM11.5 4.35L21 3V12.5H11.5V4.35ZM11.5 13.5H21V23L11.5 21.65V13.5Z"/>
              </svg>
            </div>

            <!-- Android - bottom left, floating -->
            <div class="platform-float-2 absolute bottom-2 left-[10%] flex h-12 w-12 items-center justify-center rounded-full border border-slate-600/50 bg-slate-700/90 shadow-lg backdrop-blur-sm sm:h-14 sm:w-14 sm:left-[15%]">
              <svg class="h-6 w-6 text-green-400 sm:h-7 sm:w-7" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 18c0 .55.45 1 1 1h1v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h2v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5S5 17.33 5 16.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48C13.85 1.23 12.95 1 12 1c-.96 0-1.86.23-2.66.63L7.85.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31C6.97 3.26 6 5.01 6 7h12c0-1.99-.97-3.75-2.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/>
              </svg>
            </div>

            <!-- iOS - middle left, floating -->
            <div class="platform-float-3 absolute top-1/2 -left-4 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-slate-600/50 bg-slate-700/90 shadow-lg backdrop-blur-sm sm:h-14 sm:w-14 sm:-left-2">
              <svg class="h-6 w-6 text-slate-200 sm:h-7 sm:w-7" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- Platform status bar -->
      <div class="relative mt-10 flex flex-wrap items-center justify-center gap-3 border-t border-slate-700/50 pt-8 sm:gap-5">
        {data.items.map((item) => (
          <div class="flex items-center gap-2 rounded-full border border-slate-600/40 bg-slate-800/60 px-4 py-2 backdrop-blur-sm">
            <span class="text-xs font-medium text-slate-200 sm:text-sm">{item.name}</span>
            <span class={`rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider ${item.status === 'live' ? 'bg-emerald-500/20 text-emerald-400' : 'bg-amber-500/20 text-amber-400'}`}>
              {statusLabel[item.status]}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Floating animations for platform icons */
  @keyframes float-1 {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  @keyframes float-2 {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    33% { transform: translateY(-6px) translateX(3px); }
    66% { transform: translateY(4px) translateX(-2px); }
  }

  @keyframes float-3 {
    0%, 100% { transform: translateY(-50%) translateX(0px); }
    50% { transform: translateY(calc(-50% - 8px)) translateX(4px); }
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(16, 185, 129, 0.15); }
    50% { box-shadow: 0 0 35px rgba(16, 185, 129, 0.3); }
  }

  .platform-float-1 {
    animation: float-1 3.5s ease-in-out infinite;
  }

  .platform-float-2 {
    animation: float-2 4s ease-in-out infinite;
    animation-delay: 0.5s;
  }

  .platform-float-3 {
    animation: float-3 3.8s ease-in-out infinite;
    animation-delay: 1s;
  }

  .platform-main-card {
    animation: pulse-glow 3s ease-in-out infinite;
  }
</style>
