---
const { lang } = Astro.props

const content = {
  en: {
    title: 'Get started in 3 steps',
    steps: [
      { number: '1', title: 'Sign up', description: 'Create your free account in seconds.' },
      { number: '2', title: 'Start a chat', description: 'Create a group, channel, or DM someone directly.' },
      { number: '3', title: 'Enjoy', description: 'Chat securely, share files, and stay connected.' },
    ],
  },
  fa: {
    title: 'در ۳ قدم شروع کنید',
    steps: [
      { number: '۱', title: 'ثبت‌نام', description: 'تو چند ثانیه اکانت رایگان بسازید.' },
      { number: '۲', title: 'چت بسازید', description: 'گروه، کانال یا چت خصوصی بسازید.' },
      { number: '۳', title: 'لذت ببرید', description: 'امن چت کنید، فایل بفرستید و متصل بمونید.' },
    ],
  },
}

const data = content[lang] || content.en
---

<section class="section-block">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-2xl font-extrabold text-slate-900 dark:text-white sm:text-3xl lg:text-4xl">
        {data.title}
      </h2>
    </div>

    <div class="mt-14 grid gap-8 sm:grid-cols-3">
      {data.steps.map((step) => (
        <div class="relative text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-50 text-2xl font-extrabold text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400">
            {step.number}
          </div>
          <h3 class="mb-2 text-base font-bold text-slate-900 dark:text-white">{step.title}</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
