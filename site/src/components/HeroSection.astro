---
import { WEB_APP_URL } from '../config/urls.js'

const { t, lang } = Astro.props
---

<section class="relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-b from-emerald-50/60 via-white to-white dark:from-[#020617] dark:via-[#020617] dark:to-[#0f172a]"></div>
    <div class="absolute -top-20 left-1/3 h-[500px] w-[500px] rounded-full bg-emerald-100/50 blur-[140px] dark:bg-emerald-900/15"></div>
    <div class="absolute bottom-20 right-1/4 h-[350px] w-[350px] rounded-full bg-teal-100/40 blur-[100px] dark:bg-teal-900/10"></div>
  </div>

  <!-- Content -->
  <div class="mx-auto max-w-6xl px-6 pt-28 lg:px-8 lg:pt-36">
    <!-- Title -->
    <div class="text-center">
      <h1 class="mx-auto max-w-4xl text-4xl font-extrabold leading-[1.1] text-slate-900 dark:text-white sm:text-5xl md:text-6xl lg:text-7xl">
        {t.hero.title}
        <span class="block bg-gradient-to-r from-[#0c9d92] to-[#10b981] bg-clip-text text-transparent">
          {t.hero.titleHighlight}
        </span>
      </h1>

      <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400 sm:text-lg">
        {t.hero.description}
      </p>
    </div>

    <!-- App Preview - ABOVE buttons like Discord -->
    <div class="relative mx-auto mt-12 max-w-5xl">
      <div class="overflow-hidden rounded-t-xl border border-b-0 border-slate-200 bg-white shadow-2xl shadow-slate-900/5 dark:border-slate-700/50 dark:bg-[#0f172a] dark:shadow-emerald-500/5">
        <!-- Browser chrome -->
        <div class="flex items-center gap-2 border-b border-slate-100 bg-slate-50 px-4 py-2.5 dark:border-slate-700/50 dark:bg-slate-800/50">
          <div class="flex gap-1.5">
            <div class="h-2.5 w-2.5 rounded-full bg-red-400/70"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-yellow-400/70"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-green-400/70"></div>
          </div>
          <div class="mx-auto flex items-center gap-1.5 rounded-md bg-slate-100 px-3 py-1 text-[11px] text-slate-500 dark:bg-slate-700/50 dark:text-slate-400">
            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            web.birdx.chat
          </div>
        </div>
        <!-- App mockup -->
        <div class="relative aspect-[16/8] bg-white dark:bg-[#0f172a]">
          <!-- Sidebar -->
          <div class="absolute inset-y-0 left-0 w-[22%] border-r border-slate-100 bg-slate-50/50 p-3 dark:border-slate-700/30 dark:bg-slate-800/30">
            <div class="space-y-2.5">
              <div class="h-2.5 w-3/4 rounded bg-slate-200/80 dark:bg-slate-700/50"></div>
              <div class="h-2.5 w-1/2 rounded bg-slate-200/60 dark:bg-slate-700/30"></div>
              <div class="mt-5 space-y-2">
                <div class="flex items-center gap-2 rounded-lg bg-emerald-50 p-1.5 dark:bg-emerald-500/5">
                  <div class="h-7 w-7 rounded-full bg-emerald-200 dark:bg-emerald-500/20"></div>
                  <div class="h-2.5 w-14 rounded bg-emerald-300/60 dark:bg-emerald-500/30"></div>
                </div>
                <div class="flex items-center gap-2 p-1.5">
                  <div class="h-7 w-7 rounded-full bg-slate-200 dark:bg-slate-700/50"></div>
                  <div class="h-2.5 w-12 rounded bg-slate-200/80 dark:bg-slate-700/40"></div>
                </div>
                <div class="flex items-center gap-2 p-1.5">
                  <div class="h-7 w-7 rounded-full bg-slate-200 dark:bg-slate-700/50"></div>
                  <div class="h-2.5 w-16 rounded bg-slate-200/80 dark:bg-slate-700/40"></div>
                </div>
                <div class="flex items-center gap-2 p-1.5">
                  <div class="h-7 w-7 rounded-full bg-sky-200 dark:bg-sky-500/20"></div>
                  <div class="h-2.5 w-20 rounded bg-slate-200/80 dark:bg-slate-700/40"></div>
                </div>
              </div>
            </div>
          </div>
          <!-- Chat area -->
          <div class="absolute inset-y-0 left-[22%] right-0 flex flex-col p-4">
            <div class="flex items-center gap-2 border-b border-slate-100 pb-2.5 dark:border-slate-700/30">
              <div class="h-7 w-7 rounded-full bg-emerald-200 dark:bg-emerald-500/20"></div>
              <div class="h-2.5 w-24 rounded bg-slate-200 dark:bg-slate-700/50"></div>
            </div>
            <div class="flex-1 space-y-4 py-4">
              <div class="flex items-start gap-2.5">
                <div class="h-6 w-6 shrink-0 rounded-full bg-emerald-200 dark:bg-emerald-500/20"></div>
                <div class="rounded-xl bg-slate-100 px-3.5 py-2 dark:bg-slate-800/50">
                  <div class="h-2.5 w-28 rounded bg-slate-300/80 dark:bg-slate-600/50"></div>
                </div>
              </div>
              <div class="flex items-start justify-end gap-2.5">
                <div class="rounded-xl bg-emerald-50 px-3.5 py-2 dark:bg-emerald-500/10">
                  <div class="h-2.5 w-36 rounded bg-emerald-300/50 dark:bg-emerald-500/30"></div>
                </div>
              </div>
              <div class="flex items-start gap-2.5">
                <div class="h-6 w-6 shrink-0 rounded-full bg-sky-200 dark:bg-sky-500/20"></div>
                <div class="rounded-xl bg-slate-100 px-3.5 py-2 dark:bg-slate-800/50">
                  <div class="h-2.5 w-44 rounded bg-slate-300/80 dark:bg-slate-600/50"></div>
                  <div class="mt-1.5 h-2.5 w-24 rounded bg-slate-300/60 dark:bg-slate-600/30"></div>
                </div>
              </div>
            </div>
            <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 dark:border-slate-700/50 dark:bg-slate-800/30">
              <div class="h-2.5 w-20 rounded bg-slate-200/80 dark:bg-slate-700/40"></div>
            </div>
          </div>
        </div>
      </div>
      <!-- Glow -->
      <div class="absolute -inset-6 -z-10 rounded-3xl bg-gradient-to-r from-emerald-200/20 via-transparent to-teal-200/20 blur-2xl dark:from-emerald-500/5 dark:to-teal-500/5"></div>
    </div>

    <!-- CTAs - BELOW image like Discord -->
    <div class="relative z-10 -mt-1 flex flex-col items-center justify-center gap-4 bg-gradient-to-t from-white via-white to-white/80 pb-10 pt-8 dark:from-[#0f172a] dark:via-[#0f172a] dark:to-[#0f172a]/80 sm:flex-row">
      <a href="#app-download" class="btn-primary">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        {t.hero.cta}
      </a>
      <a href={WEB_APP_URL} class="btn-secondary">
        {t.hero.ctaSecondary}
      </a>
    </div>
  </div>
</section>
