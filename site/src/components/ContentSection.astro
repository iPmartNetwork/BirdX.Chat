---
const { section, index } = Astro.props
const isReversed = section.align === 'right'
const isAlt = index % 2 === 1

const illustrations = [
  // Section 1: Secure space
  `<div class="relative flex items-center justify-center">
    <div class="absolute h-64 w-64 rounded-full bg-emerald-100/40 blur-3xl dark:bg-emerald-900/15"></div>
    <div class="relative rounded-2xl border border-slate-200 bg-white p-6 shadow-xl dark:border-slate-700/50 dark:bg-[#0f172a]">
      <div class="flex items-center gap-3 mb-5">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-50 dark:bg-emerald-500/10">
          <svg class="h-5 w-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <div>
          <div class="h-2.5 w-20 rounded bg-slate-200 dark:bg-slate-700/60"></div>
          <div class="mt-1.5 h-2 w-14 rounded bg-slate-100 dark:bg-slate-700/30"></div>
        </div>
      </div>
      <div class="space-y-2.5">
        <div class="flex items-center gap-3 rounded-lg bg-emerald-50/80 p-2.5 dark:bg-emerald-500/5">
          <div class="h-7 w-7 rounded-full bg-emerald-200 dark:bg-emerald-500/20"></div>
          <div class="h-2.5 w-28 rounded bg-emerald-200/80 dark:bg-emerald-500/20"></div>
          <div class="ml-auto h-4 w-4 rounded-full bg-emerald-400/40 dark:bg-emerald-400/30"></div>
        </div>
        <div class="flex items-center gap-3 rounded-lg bg-slate-50 p-2.5 dark:bg-slate-800/50">
          <div class="h-7 w-7 rounded-full bg-sky-200 dark:bg-sky-500/20"></div>
          <div class="h-2.5 w-24 rounded bg-slate-200 dark:bg-slate-700/50"></div>
          <div class="ml-auto h-4 w-4 rounded-full bg-emerald-400/40 dark:bg-emerald-400/30"></div>
        </div>
        <div class="flex items-center gap-3 rounded-lg bg-slate-50 p-2.5 dark:bg-slate-800/50">
          <div class="h-7 w-7 rounded-full bg-purple-200 dark:bg-purple-500/20"></div>
          <div class="h-2.5 w-32 rounded bg-slate-200 dark:bg-slate-700/50"></div>
          <div class="ml-auto h-4 w-4 rounded-full bg-emerald-400/40 dark:bg-emerald-400/30"></div>
        </div>
      </div>
    </div>
  </div>`,
  // Section 2: File sharing
  `<div class="relative flex items-center justify-center">
    <div class="absolute h-64 w-64 rounded-full bg-teal-100/40 blur-3xl dark:bg-teal-900/15"></div>
    <div class="relative rounded-2xl border border-slate-200 bg-white p-6 shadow-xl dark:border-slate-700/50 dark:bg-[#0f172a]">
      <div class="space-y-3">
        <div class="flex items-center gap-3 rounded-xl border border-slate-100 bg-slate-50 p-3 dark:border-slate-700/30 dark:bg-slate-800/50">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-blue-50 dark:bg-blue-500/10">
            <svg class="h-4 w-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <div class="h-2.5 w-24 rounded bg-slate-300 dark:bg-slate-600/60"></div>
            <div class="mt-1 h-2 w-14 rounded bg-slate-200 dark:bg-slate-700/40"></div>
          </div>
          <div class="ml-auto text-xs text-emerald-500 font-bold">✓</div>
        </div>
        <div class="flex items-center gap-3 rounded-xl border border-slate-100 bg-slate-50 p-3 dark:border-slate-700/30 dark:bg-slate-800/50">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-purple-50 dark:bg-purple-500/10">
            <svg class="h-4 w-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <div class="h-2.5 w-28 rounded bg-slate-300 dark:bg-slate-600/60"></div>
            <div class="mt-1 h-2 w-16 rounded bg-slate-200 dark:bg-slate-700/40"></div>
          </div>
          <div class="ml-auto text-xs text-emerald-500 font-bold">✓</div>
        </div>
        <div class="flex items-center gap-3 rounded-xl border border-dashed border-emerald-300/60 bg-emerald-50/50 p-3 dark:border-emerald-500/20 dark:bg-emerald-500/5">
          <svg class="h-5 w-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
          <div class="h-2.5 w-32 rounded bg-emerald-200/60 dark:bg-emerald-500/20"></div>
        </div>
      </div>
    </div>
  </div>`,
  // Section 3: Cross-platform
  `<div class="relative flex items-center justify-center">
    <div class="absolute h-64 w-64 rounded-full bg-emerald-100/30 blur-3xl dark:bg-emerald-900/10"></div>
    <div class="relative flex items-end gap-3">
      <!-- Phone -->
      <div class="w-28 rounded-xl border border-slate-200 bg-white p-2 shadow-lg dark:border-slate-700/50 dark:bg-[#0f172a]">
        <div class="rounded-lg bg-slate-50 p-2 dark:bg-slate-800/50">
          <div class="mb-1.5 h-2 w-10 rounded bg-emerald-200/60 dark:bg-emerald-500/20"></div>
          <div class="space-y-1">
            <div class="h-1.5 w-full rounded bg-slate-200 dark:bg-slate-700/50"></div>
            <div class="h-1.5 w-3/4 rounded bg-slate-200 dark:bg-slate-700/40"></div>
          </div>
        </div>
        <div class="mt-1.5 rounded-lg bg-slate-50 p-2 dark:bg-slate-800/50">
          <div class="space-y-1">
            <div class="h-1.5 w-full rounded bg-slate-200 dark:bg-slate-700/50"></div>
            <div class="h-1.5 w-1/2 rounded bg-slate-200 dark:bg-slate-700/40"></div>
          </div>
        </div>
      </div>
      <!-- Desktop (main) -->
      <div class="w-48 rounded-xl border border-slate-200 bg-white p-2.5 shadow-xl dark:border-slate-700/50 dark:bg-[#0f172a]">
        <div class="flex gap-1 mb-1.5">
          <div class="h-1.5 w-1.5 rounded-full bg-red-300"></div>
          <div class="h-1.5 w-1.5 rounded-full bg-yellow-300"></div>
          <div class="h-1.5 w-1.5 rounded-full bg-green-300"></div>
        </div>
        <div class="rounded-lg bg-slate-50 p-2.5 dark:bg-slate-800/50">
          <div class="flex gap-2">
            <div class="w-1/3 space-y-1.5">
              <div class="h-1.5 w-full rounded bg-slate-200 dark:bg-slate-700/50"></div>
              <div class="h-1.5 w-3/4 rounded bg-slate-200 dark:bg-slate-700/40"></div>
              <div class="h-1.5 w-full rounded bg-emerald-200/50 dark:bg-emerald-500/15"></div>
            </div>
            <div class="w-2/3 space-y-1.5">
              <div class="h-1.5 w-full rounded bg-slate-200 dark:bg-slate-700/50"></div>
              <div class="h-1.5 w-3/4 rounded bg-slate-200 dark:bg-slate-700/40"></div>
              <div class="h-1.5 w-1/2 rounded bg-emerald-200/50 dark:bg-emerald-500/15"></div>
            </div>
          </div>
        </div>
      </div>
      <!-- Tablet -->
      <div class="hidden w-36 rounded-xl border border-slate-200 bg-white p-2 shadow-lg sm:block dark:border-slate-700/50 dark:bg-[#0f172a]">
        <div class="rounded-lg bg-slate-50 p-2 dark:bg-slate-800/50">
          <div class="mb-1.5 h-2 w-12 rounded bg-emerald-200/60 dark:bg-emerald-500/20"></div>
          <div class="space-y-1">
            <div class="h-1.5 w-full rounded bg-slate-200 dark:bg-slate-700/50"></div>
            <div class="h-1.5 w-3/4 rounded bg-slate-200 dark:bg-slate-700/40"></div>
            <div class="h-1.5 w-1/2 rounded bg-slate-200 dark:bg-slate-700/30"></div>
          </div>
        </div>
      </div>
    </div>
  </div>`,
]
---

<section class={`section-block ${isAlt ? 'section-block-alt' : ''}`}>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class={`flex flex-col items-center gap-10 lg:flex-row lg:gap-16 ${isReversed ? 'lg:flex-row-reverse' : ''}`}>
      <!-- Text -->
      <div class="flex-1 text-center lg:text-start">
        <h2 class="text-2xl font-extrabold text-slate-900 dark:text-white sm:text-3xl lg:text-4xl">
          {section.title}
        </h2>
        <p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 sm:text-base">
          {section.description}
        </p>
      </div>
      <!-- Illustration -->
      <div class="flex-1">
        <Fragment set:html={illustrations[index]} />
      </div>
    </div>
  </div>
</section>
