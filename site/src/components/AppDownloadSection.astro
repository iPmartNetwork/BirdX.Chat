---
import { MOBILE_APP_URL, WEB_APP_URL } from '../config/urls.js'

const { lang } = Astro.props

const content = {
  en: {
    title: 'Download BirdX',
    subtitle: 'Get BirdX on your favorite platform and start chatting securely.',
    platforms: [
      {
        name: 'Windows',
        description: 'Download for Windows 10/11',
        icon: 'windows',
        link: MOBILE_APP_URL,
        badge: 'DOWNLOAD',
        available: true,
      },
      {
        name: 'Android',
        description: 'Download APK or get it on Google Play',
        icon: 'android',
        link: MOBILE_APP_URL,
        badge: 'DOWNLOAD',
        available: true,
      },
      {
        name: 'iOS',
        description: 'Available via TestFlight',
        icon: 'ios',
        link: MOBILE_APP_URL,
        badge: 'TESTFLIGHT',
        available: true,
      },
      {
        name: 'Web App',
        description: 'No download needed — open in browser',
        icon: 'web',
        link: WEB_APP_URL,
        badge: 'OPEN',
        available: true,
      },
    ],
  },
  fa: {
    title: 'دانلود بردایکس',
    subtitle: 'بردایکس رو روی پلتفرم مورد علاقه‌تون نصب کنید و شروع کنید.',
    platforms: [
      {
        name: 'ویندوز',
        description: 'دانلود برای ویندوز ۱۰/۱۱',
        icon: 'windows',
        link: MOBILE_APP_URL,
        badge: 'دانلود',
        available: true,
      },
      {
        name: 'اندروید',
        description: 'دانلود فایل APK یا از گوگل پلی',
        icon: 'android',
        link: MOBILE_APP_URL,
        badge: 'دانلود',
        available: true,
      },
      {
        name: 'آی‌او‌اس',
        description: 'از طریق TestFlight در دسترسه',
        icon: 'ios',
        link: MOBILE_APP_URL,
        badge: 'TESTFLIGHT',
        available: true,
      },
      {
        name: 'وب اپ',
        description: 'بدون نصب — مستقیم تو مرورگر باز کنید',
        icon: 'web',
        link: WEB_APP_URL,
        badge: 'باز کردن',
        available: true,
      },
    ],
  },
}

const data = content[lang] || content.en

const icons = {
  windows: `<svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor"><path d="M3 12.5V5.5L10.5 4.5V12.5H3ZM3 13.5H10.5V21.5L3 20.5V13.5ZM11.5 4.35L21 3V12.5H11.5V4.35ZM11.5 13.5H21V23L11.5 21.65V13.5Z"/></svg>`,
  android: `<svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18c0 .55.45 1 1 1h1v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h2v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5S5 17.33 5 16.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48C13.85 1.23 12.95 1 12 1c-.96 0-1.86.23-2.66.63L7.85.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31C6.97 3.26 6 5.01 6 7h12c0-1.99-.97-3.75-2.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/></svg>`,
  ios: `<svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>`,
  web: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>`,
}

const iconColors = {
  windows: 'text-sky-400',
  android: 'text-green-400',
  ios: 'text-slate-200',
  web: 'text-emerald-400',
}
---

<section id="app-download" class="section-block section-block-alt">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center">
      <h2 class="text-2xl font-extrabold text-slate-900 dark:text-white sm:text-3xl lg:text-4xl">
        {data.title}
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-sm text-slate-500 dark:text-slate-400 sm:text-base">
        {data.subtitle}
      </p>
    </div>

    <!-- Download Grid -->
    <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {data.platforms.map((platform) => (
        <a
          href={platform.link}
          class="group flex flex-col items-center rounded-2xl border border-slate-200 bg-white p-6 text-center transition-all duration-300 hover:border-emerald-300 hover:shadow-lg hover:shadow-emerald-500/5 hover:-translate-y-1 dark:border-slate-700/40 dark:bg-slate-800/40 dark:hover:border-emerald-500/40 dark:hover:bg-slate-800/60"
        >
          <div class={`mb-4 ${iconColors[platform.icon]}`}>
            <Fragment set:html={icons[platform.icon]} />
          </div>
          <h3 class="mb-1 text-base font-bold text-slate-900 dark:text-white">{platform.name}</h3>
          <p class="mb-4 text-xs text-slate-500 dark:text-slate-400">{platform.description}</p>
          <span class="mt-auto inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-4 py-1.5 text-xs font-bold text-emerald-700 transition-colors group-hover:bg-emerald-100 dark:bg-emerald-500/10 dark:text-emerald-400 dark:group-hover:bg-emerald-500/20">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            {platform.badge}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
