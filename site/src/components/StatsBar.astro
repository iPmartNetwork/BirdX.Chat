---
const { lang } = Astro.props

const stats = {
  en: [
    { value: 'Open Source', label: 'Since 2026' },
    { value: 'MIT', label: 'License' },
    { value: '100%', label: 'Free Forever' },
    { value: 'Self-Hosted', label: 'Full Control' },
  ],
  fa: [
    { value: 'اوپن سورس', label: 'از ۲۰۲۶' },
    { value: 'MIT', label: 'لایسنس' },
    { value: '۱۰۰٪', label: 'رایگان برای همیشه' },
    { value: 'خود‌میزبان', label: 'کنترل کامل' },
  ],
}

const data = stats[lang] || stats.en
---

<section class="border-y border-slate-100 bg-slate-50/50 py-8 dark:border-slate-800 dark:bg-[#0f172a]/50">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
      {data.map((stat) => (
        <div class="text-center">
          <p class="text-lg font-extrabold text-slate-900 dark:text-white sm:text-xl">{stat.value}</p>
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
