---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { getTranslations } from '../i18n/translations.js'

const t = getTranslations('en')
---

<BaseLayout title="BirdX - Documentation" description="Learn how to install, configure, and use BirdX on your own server." lang="en" dir="ltr">
  <Header t={t} lang="en" />
  <main class="pt-24 pb-16">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white sm:text-4xl">Documentation</h1>
      <p class="mt-4 text-base text-slate-600 dark:text-slate-400">Everything you need to install, configure, and run BirdX.</p>

      <!-- Quick Start -->
      <section class="mt-12">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Quick Start</h2>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">Get BirdX running on your server in under 5 minutes.</p>
        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-700/50 dark:bg-slate-800/50">
          <pre class="overflow-x-auto text-sm text-slate-800 dark:text-slate-200"><code>git clone https://github.com/iPmartNetwork/BirdX.Chat.git
cd BirdX
npm install
npm run build
npm start</code></pre>
        </div>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">Or use the one-line installer:</p>
        <div class="mt-2 rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-700/50 dark:bg-slate-800/50">
          <pre class="overflow-x-auto text-sm text-slate-800 dark:text-slate-200"><code>bash &lt;(curl -fsSL https://raw.githubusercontent.com/iPmartNetwork/BirdX.Chat/master/scripts/install.sh)</code></pre>
        </div>
      </section>

      <!-- Requirements -->
      <section class="mt-12">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Requirements</h2>
        <div class="mt-4 overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700/50">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 dark:bg-slate-800/50">
              <tr>
                <th class="px-4 py-3 text-left font-semibold text-slate-700 dark:text-slate-300">Requirement</th>
                <th class="px-4 py-3 text-left font-semibold text-slate-700 dark:text-slate-300">Minimum</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-700/30">
              <tr><td class="px-4 py-2.5 text-slate-600 dark:text-slate-400">Node.js</td><td class="px-4 py-2.5 text-slate-800 dark:text-slate-200">24+</td></tr>
              <tr><td class="px-4 py-2.5 text-slate-600 dark:text-slate-400">npm</td><td class="px-4 py-2.5 text-slate-800 dark:text-slate-200">11+</td></tr>
              <tr><td class="px-4 py-2.5 text-slate-600 dark:text-slate-400">Protocol</td><td class="px-4 py-2.5 text-slate-800 dark:text-slate-200">HTTPS in production</td></tr>
              <tr><td class="px-4 py-2.5 text-slate-600 dark:text-slate-400">Domain</td><td class="px-4 py-2.5 text-slate-800 dark:text-slate-200">Public domain for PWA/Push/WebRTC</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Configuration -->
      <section class="mt-12">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Configuration</h2>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">Create a <code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs dark:bg-slate-700">.env</code> file from <code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs dark:bg-slate-700">.env.example</code>:</p>
        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-700/50 dark:bg-slate-800/50">
          <pre class="overflow-x-auto text-xs text-slate-800 dark:text-slate-200"><code># Server
SERVER_PORT=5174
APP_ENV=production

# Auth
ACCOUNT_CREATION=true
ADMIN_USERNAMES=admin

# Upload
FILE_UPLOAD=true
FILE_UPLOAD_MAX_SIZE=26214400

# Security
STORAGE_ENCRYPTION_KEY=your_random_key
VAPID_PUBLIC_KEY=your_vapid_public
VAPID_PRIVATE_KEY=your_vapid_private</code></pre>
        </div>
        <p class="mt-3 text-xs text-amber-600 dark:text-amber-400">⚠️ Do not change STORAGE_ENCRYPTION_KEY after first run.</p>
      </section>

      <!-- Deployment -->
      <section class="mt-12">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Production Deployment</h2>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">Deploy with PM2 or systemd for production:</p>
        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-700/50 dark:bg-slate-800/50">
          <pre class="overflow-x-auto text-sm text-slate-800 dark:text-slate-200"><code># With PM2
npm install -g pm2
pm2 start npm --name birdx -- start
pm2 save

# With systemd
sudo systemctl enable birdx
sudo systemctl start birdx</code></pre>
        </div>
      </section>

      <!-- Update -->
      <section class="mt-12">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Updating</h2>
        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-700/50 dark:bg-slate-800/50">
          <pre class="overflow-x-auto text-sm text-slate-800 dark:text-slate-200"><code>cd /opt/birdx
git fetch origin && git reset --hard origin/master
npm --prefix server install
npm --prefix client install
npm --prefix client run build
systemctl restart birdx</code></pre>
        </div>
      </section>

      <!-- Database -->
      <section class="mt-12">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Database & Backups</h2>
        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-700/50 dark:bg-slate-800/50">
          <pre class="overflow-x-auto text-sm text-slate-800 dark:text-slate-200"><code>npm --prefix server run db:backup    # Create backup
npm --prefix server run db:restore   # Restore backup
npm --prefix server run db:migrate   # Run migrations
npm --prefix server run db:vacuum    # Optimize database</code></pre>
        </div>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">Backups are also available from the Admin Panel → Maintenance tab.</p>
      </section>

      <!-- Admin -->
      <section class="mt-12">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Admin Setup</h2>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">Set admin usernames in your <code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs dark:bg-slate-700">.env</code> file:</p>
        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-700/50 dark:bg-slate-800/50">
          <pre class="overflow-x-auto text-sm text-slate-800 dark:text-slate-200"><code>ADMIN_USERNAMES=admin,admin2</code></pre>
        </div>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">Restart the server, then access the admin panel at <code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs dark:bg-slate-700">/admin</code>.</p>
      </section>

      <!-- Links -->
      <section class="mt-12 rounded-xl border border-emerald-200 bg-emerald-50 p-6 dark:border-emerald-500/20 dark:bg-emerald-500/5">
        <h3 class="text-base font-bold text-slate-900 dark:text-white">More Resources</h3>
        <ul class="mt-3 space-y-2">
          <li><a href="https://github.com/iPmartNetwork/BirdX.Chat" target="_blank" rel="noopener" class="text-sm text-emerald-700 hover:underline dark:text-emerald-400">GitHub Repository</a></li>
          <li><a href="https://github.com/iPmartNetwork/BirdX.Chat/issues" target="_blank" rel="noopener" class="text-sm text-emerald-700 hover:underline dark:text-emerald-400">Report a Bug</a></li>
          <li><a href="https://github.com/iPmartNetwork/BirdX.Chat/blob/master/CHANGELOG.md" target="_blank" rel="noopener" class="text-sm text-emerald-700 hover:underline dark:text-emerald-400">Changelog</a></li>
        </ul>
      </section>
    </div>
  </main>
  <Footer t={t} lang="en" />
</BaseLayout>
