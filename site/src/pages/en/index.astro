---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Header from '../../components/Header.astro'
import HeroSection from '../../components/HeroSection.astro'
import StatsBar from '../../components/StatsBar.astro'
import ContentSection from '../../components/ContentSection.astro'
import HowItWorks from '../../components/HowItWorks.astro'
import FeaturesSection from '../../components/FeaturesSection.astro'
import PlatformSection from '../../components/PlatformSection.astro'
import AppDownloadSection from '../../components/AppDownloadSection.astro'
import FAQSection from '../../components/FAQSection.astro'
import DownloadSection from '../../components/DownloadSection.astro'
import Footer from '../../components/Footer.astro'
import { getTranslations } from '../../i18n/translations.js'

const t = getTranslations('en')
---

<BaseLayout title="BirdX - Secure Chat & File Sharing Platform" description="BirdX was built so everyone can enjoy private, secure communication. Real-time messaging, file sharing, and complete data ownership." lang="en" dir="ltr">
  <Header t={t} lang="en" />
  <main>
    <HeroSection t={t} lang="en" />
    <StatsBar lang="en" />
    <div class="fade-in-section">
      {t.sections.map((section, index) => (
        <ContentSection section={section} index={index} />
      ))}
    </div>
    <div class="fade-in-section">
      <HowItWorks lang="en" />
    </div>
    <div class="fade-in-section">
      <FeaturesSection t={t} />
    </div>
    <div class="fade-in-section">
      <PlatformSection t={t} lang="en" />
    </div>
    <div class="fade-in-section">
      <AppDownloadSection lang="en" />
    </div>
    <div class="fade-in-section">
      <FAQSection lang="en" />
    </div>
    <div class="fade-in-section">
      <DownloadSection t={t} />
    </div>
  </main>
  <Footer t={t} lang="en" />
</BaseLayout>
