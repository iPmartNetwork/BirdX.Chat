---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import HeroSection from '../components/HeroSection.astro'
import StatsBar from '../components/StatsBar.astro'
import ContentSection from '../components/ContentSection.astro'
import HowItWorks from '../components/HowItWorks.astro'
import FeaturesSection from '../components/FeaturesSection.astro'
import PlatformSection from '../components/PlatformSection.astro'
import AppDownloadSection from '../components/AppDownloadSection.astro'
import FAQSection from '../components/FAQSection.astro'
import DownloadSection from '../components/DownloadSection.astro'
import Footer from '../components/Footer.astro'
import { getTranslations } from '../i18n/translations.js'

const t = getTranslations('fa')
---

<BaseLayout title="بردایکس - پلتفرم چت و ارسال فایل امن" description="بردایکس رو ساختیم تا همه بتونن از یه فضای امن و خصوصی برای ارتباطاتشون استفاده کنن." lang="fa" dir="rtl">
  <Header t={t} lang="fa" />
  <main>
    <HeroSection t={t} lang="fa" />
    <StatsBar lang="fa" />
    <div class="fade-in-section">
      {t.sections.map((section, index) => (
        <ContentSection section={section} index={index} />
      ))}
    </div>
    <div class="fade-in-section">
      <HowItWorks lang="fa" />
    </div>
    <div class="fade-in-section">
      <FeaturesSection t={t} />
    </div>
    <div class="fade-in-section">
      <PlatformSection t={t} lang="fa" />
    </div>
    <div class="fade-in-section">
      <AppDownloadSection lang="fa" />
    </div>
    <div class="fade-in-section">
      <FAQSection lang="fa" />
    </div>
    <div class="fade-in-section">
      <DownloadSection t={t} />
    </div>
  </main>
  <Footer t={t} lang="fa" />
</BaseLayout>
