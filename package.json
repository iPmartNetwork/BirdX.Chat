{
  "name": "birdx",
  "version": "1.0.1",
  "private": true,
  "license": "MIT",
  "description": "BirdX - Advanced self-hosted chat and file sharing platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/iPmartNetwork/BirdX.Chat.git"
  },
  "bugs": {
    "url": "https://github.com/iPmartNetwork/BirdX.Chat/issues"
  },
  "homepage": "https://github.com/iPmartNetwork/BirdX.Chat#readme",
  "scripts": {
    "dev": "concurrently \"npm --prefix client run dev\" \"npm --prefix server run dev\"",
    "dev:desktop": "npm --prefix apps/desktop run start",
    "build:desktop": "npm --prefix apps/desktop run build && node apps/desktop/scripts/copy-installer.js",
    "build:android": "npm --prefix apps/mobile run sync && npm --prefix apps/mobile run build:android:debug && npm --prefix apps/mobile run copy:apk",
    "build:apps": "npm run build:desktop",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "build": "npm --prefix client run build",
    "build:all": "npm run build",
    "preview": "npm --prefix client run preview",
    "start": "npm --prefix server run start"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "concurrently": "^9.2.1",
    "semantic-release": "^25.0.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "volta": {
    "node": "24.11.1",
    "npm": "11.12.1"
  },
  "dependencies": {
    "socket.io": "^4.8.3"
  }
}
